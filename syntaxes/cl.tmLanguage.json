{
  "name": "CL",
  "scopeName": "source.cl",
  "fileTypes": ["clle", "clp"],
  "patterns": [
    { "include": "#labels" },
    { "include": "#control-keywords" },
    { "include": "#operator-keywords" },
    { "include": "#storage-type" },
    { "include": "#variables" },
    { "include": "#constants" },
    { "include": "#comments" },
    { "include": "#strings" }
  ],
  "repository": {
    "labels": {
      "patterns": [
        {
          "name": "meta.label.cl",
          "begin": "^\\s*([A-Za-z]+):",
          "beginCaptures": {
            "1": { "name": "entity.name.function.cl" }
          },
          "end": "\\s"
        }
      ]
    },
    "control-keywords": {
      "patterns": [
        {
          "name": "keyword.control.cl",
          "match": "(?i)\\b(if|then|do|enddo|goto|cond|opnqryf|ovrdbf|ovrprtf|rtvusrprf|chgjob|clof)\\b"
        }
      ]
    },
    "operator-keywords": {
      "patterns": [
        {
          "name": "keyword.operator.cl",
          "match": "(?i)\\b(pgm|endpgm|chgvar|rcvmsg|sndpgmmsg|monmsg|clrpfm|call|rclrsc|parm)\\b"
        }
      ]
    },
    "storage-type": {
      "patterns": [
        {
          "name": "storage.type.cl",
          "match": "(?i)\\b(dcl)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "storage.type.cl",
          "match": "(?i)(&[a-z]+)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.cl",
          "match": "(?i)\\*([a-z]+)\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.block.cl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.cl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.cl",
              "match": "\\\\."
            }
          ]
        }
      ]
    }
  }
}
